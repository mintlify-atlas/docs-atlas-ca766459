  "keyFeatures": [
    "Full donation lifecycle management (PENDIENTE → CONFIRMADA → CANCELADA)",
    "Donor (Donante) management with CUIT validation and audit history",
    "Product catalog with 16 food categories and multiple units of measure",
    "Institution management with payment status tracking and pagination",
    "Dispatch note (Remito) and line-item (DetalleRemito) management",
    "Invoice (Factura) generation from confirmed donations",
    "JWT-based authentication with role-based access control (DEPOSITO, TESORERIA, INSTITUCIONAL)",
    "Granular permission system with 35+ individual authorities",
    "Hibernate Envers auditing for donors and institutions",
    "Dockerized deployment with MySQL backend"
  ],
